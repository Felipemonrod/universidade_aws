# Normaliza line endings para LF no repositório.
# Importante: Dockerfile e scripts shell DEVEM ter LF (não CRLF) ou o Docker falha.

# Padrão: normaliza tudo para LF no repo, converte para CRLF no checkout (Windows)
* text=auto eol=lf

# Java e recursos — sempre LF
*.java        text eol=lf
*.properties  text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.xml         text eol=lf
*.sql         text eol=lf
*.html        text eol=lf
*.md          text eol=lf

# Scripts shell — obrigatoriamente LF (quebra no Linux/Docker com CRLF)
*.sh          text eol=lf
Dockerfile    text eol=lf

# Binários — sem conversão
*.jar         binary
*.png         binary
*.jpg         binary
*.gif         binary
